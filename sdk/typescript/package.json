{
  "name": "latchgate",
  "version": "0.2.0",
  "description": "TypeScript SDK for the LatchGate action authorization gateway",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "latchgate",
    "ai",
    "agent",
    "authorization",
    "security"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.1.0"
  }
}
